{
  "threat_model_version": "1.0.0",
  "last_updated": "",
  "security_team_contacts": [],
  "compliance_requirements": [],
  "scan_frequency": "on_commit",
  "severity_thresholds": {
    "block_merge": ["CRITICAL"],
    "require_review": ["HIGH", "CRITICAL"],
    "notify_security_team": ["CRITICAL"]
  },
  "vulnerability_patterns": {
    "enabled": [
      "sql_injection",
      "xss",
      "command_injection",
      "path_traversal",
      "auth_bypass",
      "idor",
      "mass_assignment",
      "hardcoded_credentials",
      "insecure_deserialization",
      "xxe"
    ],
    "custom_patterns_path": null
  },
  "dependency_scan": {
    "enabled": true,
    "cve_lookback_months": 12,
    "ignore_dev_dependencies": false
  },
  "false_positive_config": {
    "confidence_threshold": 0.8,
    "exclude_test_files": true,
    "exclude_documentation": true,
    "acknowledged_findings_path": ".factory/security/acknowledged.json"
  }
}
