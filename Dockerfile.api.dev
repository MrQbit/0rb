# rak00n dev API image — runs the pre-built API bundle under Bun.
FROM oven/bun:1.3.12-slim
WORKDIR /opt/rak00n

# Docker CLI + compose plugin (multi-arch, no network) — lets the agent build,
# sandbox, and promote new versions of itself when RAK00N_SELF_MODIFY_ENABLED=1.
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker:cli /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash coreutils findutils grep sed gawk \
      git curl jq python3 \
      ca-certificates tini \
    && rm -rf /var/lib/apt/lists/*
RUN groupadd -g 10001 rak00n && useradd -u 10001 -g rak00n -d /home/rak00n -m rak00n && \
    mkdir -p /workspace /workspace/rak00n-files /memory /home/rak00n/.rak00n && chown -R rak00n:rak00n /workspace /memory /home/rak00n/.rak00n

# Bake the rak00n settings (enable auto-memory + the dream/consolidation).
COPY config/rak00n-settings.json /home/rak00n/.rak00n/settings.json
RUN chown rak00n:rak00n /home/rak00n/.rak00n/settings.json

# API bundle
COPY dist/api.mjs /opt/rak00n/api.mjs

# Skills (markdown definitions loaded at runtime)
COPY dist/skills/ /opt/rak00n/skills/

# Optional supporting files (security-references, docs)
COPY dist/security-references/ /opt/rak00n/security-references/
COPY dist/README.md /opt/rak00n/README.md
COPY dist/ARCHITECTURE.md /opt/rak00n/ARCHITECTURE.md

USER rak00n
WORKDIR /workspace
ENV RAK00N_API_PORT=8080 \
    RAK00N_API_HOST=0.0.0.0 \
    RAK00N_API_WORKSPACE_ROOT=/workspace \
    NODE_ENV=production
EXPOSE 8080
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bun", "run", "/opt/rak00n/api.mjs"]
