# orb2 dev API image — runs the pre-built API bundle under Bun.
FROM oven/bun:1.3.12-slim
WORKDIR /opt/orb2

# Docker CLI + compose plugin (multi-arch, no network) — lets the agent build,
# sandbox, and promote new versions of itself when ORB2_SELF_MODIFY_ENABLED=1.
COPY --from=docker:cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker:cli /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose
RUN apt-get update && apt-get install -y --no-install-recommends \
      bash coreutils findutils grep sed gawk \
      git curl jq python3 \
      ca-certificates tini \
    && rm -rf /var/lib/apt/lists/*
RUN groupadd -g 10001 orb2 && useradd -u 10001 -g orb2 -d /home/orb2 -m orb2 && \
    mkdir -p /workspace /workspace/orb2-files /memory /home/orb2/.orb2 && chown -R orb2:orb2 /workspace /memory /home/orb2/.orb2

# Bake the orb2 settings (enable auto-memory + the dream/consolidation).
COPY config/orb2-settings.json /home/orb2/.orb2/settings.json
RUN chown orb2:orb2 /home/orb2/.orb2/settings.json

# API bundle
COPY dist/api.mjs /opt/orb2/api.mjs

# Skills (markdown definitions loaded at runtime)
COPY dist/skills/ /opt/orb2/skills/

# Optional supporting files (security-references, docs)
COPY dist/security-references/ /opt/orb2/security-references/
COPY dist/README.md /opt/orb2/README.md
COPY dist/ARCHITECTURE.md /opt/orb2/ARCHITECTURE.md

USER orb2
WORKDIR /workspace
ENV ORB2_API_PORT=8080 \
    ORB2_API_HOST=0.0.0.0 \
    ORB2_API_WORKSPACE_ROOT=/workspace \
    NODE_ENV=production
EXPOSE 8080
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bun", "run", "/opt/orb2/api.mjs"]
