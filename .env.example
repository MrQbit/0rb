# ── rak00n configuration ──────────────────────────────────────────────────
# Copy to `.env` (next to docker-compose.spark.yml) and fill in. `.env` is
# gitignored — never commit real secrets. `scripts/install.sh` creates this
# for you and generates RAK00N_AUTH_SECRET automatically.

# ── Auth (email + one-time-code, allowlisted) ──
RAK00N_API_AUTH_REQUIRED=1
# A long random secret that signs sessions + OTP codes. install.sh fills this.
RAK00N_AUTH_SECRET=REPLACE_WITH_RANDOM_SECRET
# Comma-separated emails allowed to sign in (the first is the owner).
RAK00N_AUTH_ALLOWED_EMAILS=you@example.com
# Mark the session cookie Secure (use when serving over HTTPS / Tailscale).
RAK00N_AUTH_COOKIE_SECURE=1

# ── Email delivery for OTP codes (Gmail: use an App Password) ──
RAK00N_SMTP_HOST=smtp.gmail.com
RAK00N_SMTP_PORT=465
RAK00N_SMTP_USER=youragent@gmail.com
RAK00N_SMTP_PASS=your_gmail_app_password
RAK00N_SMTP_FROM=youragent@gmail.com

# ── Telegram channel (optional) — talk to the agent from Telegram ──
# Bot token from @BotFather; owner id is your numeric Telegram chat id.
RAK00N_TELEGRAM_BOT_TOKEN=
RAK00N_TELEGRAM_OWNER_ID=

# ── WhatsApp bridge (optional) — link your own WhatsApp via QR ──
# Comma-separated E.164 numbers allowed to text the agent (yours = self-chat).
RAK00N_WHATSAPP_ALLOWED=
# Shared secret for the bridge→api webhook. install.sh generates one.
RAK00N_WHATSAPP_BRIDGE_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Remote access (set after running scripts/setup-tailscale.sh) ──
# Your tailnet URL, e.g. https://spark.tailXXXXXX.ts.net
RAK00N_PUBLIC_URL=

# ── Web search (SearXNG runs as a compose service; no key needed) ──
RAK00N_SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=change-me-searxng-secret
# Optional: use Brave Search instead (free key from brave.com/search/api)
RAK00N_BRAVE_API_KEY=

# ── Connected apps (or set from Settings → Apps) ──
# YouTube Data API v3 key (Google Cloud console) — search + play videos
RAK00N_YOUTUBE_API_KEY=
# Spotify app (developer.spotify.com) — client credentials, search + play music
RAK00N_SPOTIFY_CLIENT_ID=
RAK00N_SPOTIFY_CLIENT_SECRET=
# NewsAPI key (newsapi.org) — search news / headlines
RAK00N_NEWSAPI_KEY=
# Vercel — publish shareable pages to a public vercel.app URL (account token)
RAK00N_VERCEL_TOKEN=
RAK00N_VERCEL_TEAM_ID=

# ── Self-evolution (agent can build + sandbox-test + promote its own code) ──
# Requires the repo + docker socket mounted into rak00n-api (compose does this).
RAK00N_SELF_MODIFY_ENABLED=1
# Absolute host path of this repo (used for docker-in-docker bind mounts).
RAK00N_SELF_SRC_HOST=/home/youruser/rak00n

# ── Ports ──
RAK00N_UI_PORT=9080
RAK00N_UI_HTTPS_PORT=9443
