# Reuse the orb2-api base (bun:slim) — already in registry, no network pull needed
FROM orb2-api:dev
USER root
WORKDIR /app
COPY canvas-pod/server.js /app/server.js
RUN mkdir -p /workspace && chown -R orb2:orb2 /workspace /app
USER orb2
WORKDIR /workspace
ENV CANVAS_WORKSPACE=/workspace \
    RPC_PORT=9090 \
    STATIC_PORT=5173 \
    NODE_ENV=production
EXPOSE 9090 5173
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bun", "run", "/app/server.js"]
