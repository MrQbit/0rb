{
  "name": "orb2-desktop",
  "productName": "orb2",
  "version": "0.1.0",
  "private": true,
  "description": "orb2 desktop shell — loads the orb console as a desktop-layer app with a small privileged capability bridge (terminal / docker / files / native browser).",
  "license": "SEE LICENSE IN ../LICENSE",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ORB2_URL=http://localhost:9080 electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "auto-launch": "^5.0.6"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0",
    "dockerode": "^4.0.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.orb2.desktop",
    "productName": "orb2",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "assets/**"],
    "win": { "target": ["nsis"], "icon": "assets/icon.ico" },
    "mac": { "target": ["dmg"], "icon": "assets/icon.icns", "category": "public.app-category.productivity" },
    "linux": { "target": ["AppImage", "deb"], "icon": "assets/icon.png", "category": "Utility" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
