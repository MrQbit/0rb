# rak00n single-user environment template
# Copy to .env and fill in your values.

# ── Owner token (required for remote access) ──────────────────────
# This token doubles as the bootstrap admin key.
# Generate with: openssl rand -hex 32 | sed 's/^/rak00n_/'
RAK00N_OWNER_TOKEN=rak00n_your_secret_here

# ── Auth (set to 1 when exposing via Cloudflare tunnel or Tailscale) ──
# Leave unset or 0 for local-only access (no auth friction).
# RAK00N_API_AUTH_REQUIRED=1

# ── Local vLLM ────────────────────────────────────────────────────
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MODEL=qwen3-coder-next

# ── Server ────────────────────────────────────────────────────────
RAK00N_API_PORT=9080
AGENT_ID=rakoon

# ── WhatsApp (optional) ───────────────────────────────────────────
# RAK00N_OWNER_PHONE=+1234567890

# ── Voice / PersonaPlex (optional) ────────────────────────────────
# RAK00N_VOICE_ENABLED=1
# RAK00N_HF_TOKEN=hf_your_token_here
