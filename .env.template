# orb2 Environment Configuration
# Copy to .env and fill in your values.

# ── Local vLLM (default provider) ──────────────────────────────────
VLLM_MODEL=Qwen/Qwen3-Coder-Next
VLLM_SERVED_NAME=qwen3-coder-next
VLLM_TP=1
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEM=0.90

# HuggingFace token (for gated models)
HF_TOKEN=

# Host path for HuggingFace model cache (persists downloads)
HF_CACHE_DIR=~/.cache/huggingface

# ── Anthropic Foundry (optional fallback) ──────────────────────────
FOUNDRY_BASE_URL=
FOUNDRY_API_KEY=
FOUNDRY_RESOURCE=
FOUNDRY_DEFAULT_MODEL=claude-sonnet-4-6

# ── OpenAI (optional fallback) ─────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── General ────────────────────────────────────────────────────────
# API_PORT=9080
# VLLM_PORT=8000
