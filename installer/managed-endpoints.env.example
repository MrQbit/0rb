# Copy this file to installer/managed-endpoints.env and fill real values.
# Keep installer/managed-endpoints.env out of git.

# Required: 32+ random bytes in hex/string.
RAK00N_BUILD_SECRET=

# Slot 1 (required)
RAK00N_MANAGED_KEY_1=
RAK00N_MANAGED_ENDPOINT_1=https://your-project.openai.azure.com
RAK00N_MANAGED_MODEL_1=gpt-4o
RAK00N_MANAGED_LABEL_1=RAK00N Primary (GPT-4o)

# Slot 2 (optional)
RAK00N_MANAGED_KEY_2=
RAK00N_MANAGED_ENDPOINT_2=https://your-project.openai.azure.com
RAK00N_MANAGED_MODEL_2=o1-mini
RAK00N_MANAGED_LABEL_2=RAK00N Reasoning (o1-mini)

# Slot 3 (optional)
RAK00N_MANAGED_KEY_3=
RAK00N_MANAGED_ENDPOINT_3=https://your-project.openai.azure.com
RAK00N_MANAGED_MODEL_3=gpt-4o-mini
RAK00N_MANAGED_LABEL_3=RAK00N Fast (GPT-4o-mini)

# Optional compile target overrides.
# RAK00N_INSTALLER_MAC_TARGET=bun-darwin-arm64
# RAK00N_INSTALLER_WINDOWS_TARGET=bun-windows-x64
