# Copy this file to installer/managed-endpoints.env and fill real values.
# Keep installer/managed-endpoints.env out of git.

# Required: 32+ random bytes in hex/string.
ORB2_BUILD_SECRET=

# Slot 1 (required)
ORB2_MANAGED_KEY_1=
ORB2_MANAGED_ENDPOINT_1=https://your-project.openai.azure.com
ORB2_MANAGED_MODEL_1=gpt-4o
ORB2_MANAGED_LABEL_1=ORB2 Primary (GPT-4o)

# Slot 2 (optional)
ORB2_MANAGED_KEY_2=
ORB2_MANAGED_ENDPOINT_2=https://your-project.openai.azure.com
ORB2_MANAGED_MODEL_2=o1-mini
ORB2_MANAGED_LABEL_2=ORB2 Reasoning (o1-mini)

# Slot 3 (optional)
ORB2_MANAGED_KEY_3=
ORB2_MANAGED_ENDPOINT_3=https://your-project.openai.azure.com
ORB2_MANAGED_MODEL_3=gpt-4o-mini
ORB2_MANAGED_LABEL_3=ORB2 Fast (GPT-4o-mini)

# Optional compile target overrides.
# ORB2_INSTALLER_MAC_TARGET=bun-darwin-arm64
# ORB2_INSTALLER_WINDOWS_TARGET=bun-windows-x64
